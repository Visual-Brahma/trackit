{
   "action": {
      "default_icon": {
         "128": "icons/mac-logo-128.png",
         "16": "icons/mac-logo-16.png",
         "32": "icons/mac-logo-32.png",
         "48": "icons/mac-logo-48.png"
      },
      "default_popup": "popup.html",
      "default_title": "Trackit | Jitsi Attendance Collector"
   },
   "author": "Shubham Tiwari",
   "background": {
      "service_worker": "background.js"
   },
   "content_scripts": [
      {
         "js": [
            "attendance.js"
         ],
         "matches": [
            "https://meet.jit.si/*"
         ],
         "run_at": "document_idle"
      },
      {
         "js": [
            "save.js"
         ],
         "matches": [
            "https://trackit.visualbrahma.tech/*"
         ],
         "run_at": "document_idle"
      }
   ],
   "description": "Most advanced and easy to use attendance tracker for Jitsi meet.",
   "icons": {
      "128": "icons/mac-logo-128.png",
      "16": "icons/mac-logo-16.png",
      "32": "icons/mac-logo-32.png",
      "48": "icons/mac-logo-48.png"
   },
   "manifest_version": 3,
   "name": "Trackit | Jitsi Attendance Tracker",
   "permissions": [
      "storage",
      "tabs"
   ],
   "web_accessible_resources": [
      {
         "resources": ["jitsi-inject.js"],
         "matches": ["https://meet.jit.si/*"]
      }
   ],
   "version": "1.8"
}